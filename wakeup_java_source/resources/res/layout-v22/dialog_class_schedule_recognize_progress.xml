<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_e6ffffff"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/iv_back"
        android:paddingLeft="16dp"
        android:paddingTop="12dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="54dp"
        android:src="@drawable/lib_vp_top_back"
        android:scaleType="centerInside"
        android:tint="@color/black_141414"
        android:layout_centerVertical="true"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/black_141414"
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <com.suda.yzune.wakeupschedule.widget.RoundedGradientCornerProgressBar
            android:id="@+id/round_gradient_progress"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginLeft="80dp"
            android:layout_marginTop="24dp"
            android:layout_marginRight="80dp"
            android:layout_marginHorizontal="80dp"
            app:progress_colors="@array/progress_colors"
            app:progressbar_bg="@color/color_f4f5fe"
            app:progressbar_radius="5dp"
            app:progressbar_second_bg="@color/translate_load_loading_arc"
            app:secondProgress_ratio="0.68"/>
        <com.suda.yzune.wakeupschedule.widget.VerticalTextview
            android:id="@+id/text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
