<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/common_ui_dialog_bottom_sheet_shape_t_round"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.zuoyebang.design.title.CommonTitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/common_title_bar_height"
        app:titleBarColor="@android:color/transparent"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/timepicker"
        android:background="@android:color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.zuoyebang.design.picker.contrarywind.view.WheelView
            android:id="@+id/year"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:wheelview_textSize="@dimen/uxc_font_size_14"/>
        <com.zuoyebang.design.picker.contrarywind.view.WheelView
            android:id="@+id/month"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:wheelview_textSize="@dimen/uxc_font_size_14"/>
        <com.zuoyebang.design.picker.contrarywind.view.WheelView
            android:id="@+id/day"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:wheelview_textSize="@dimen/uxc_font_size_14"/>
        <com.zuoyebang.design.picker.contrarywind.view.WheelView
            android:id="@+id/hour"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:wheelview_textSize="@dimen/uxc_font_size_14"/>
        <com.zuoyebang.design.picker.contrarywind.view.WheelView
            android:id="@+id/min"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:wheelview_textSize="@dimen/uxc_font_size_14"/>
        <com.zuoyebang.design.picker.contrarywind.view.WheelView
            android:id="@+id/second"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:wheelview_textSize="@dimen/uxc_font_size_14"/>
    </LinearLayout>
</LinearLayout>
