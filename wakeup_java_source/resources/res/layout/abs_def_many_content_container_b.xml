<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/admcc_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/search_many_questions_content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.suda.yzune.wakeupschedule.aaa.activity.search.manyquestions.SearchResultTouchImageView
            android:id="@+id/search_many_questions_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <com.suda.yzune.wakeupschedule.aaa.activity.search.whole.SimplePhotoCropView
            android:id="@+id/search_many_photo_crop"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <com.suda.yzune.wakeupschedule.aaa.activity.search.whole.ImageDecorContainer
            android:id="@+id/search_many_questions_decor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <com.suda.yzune.wakeupschedule.aaa.activity.search.core.OutLineScanView
            android:id="@+id/asas_scan_anim"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/search_loading_animation"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.suda.yzune.wakeupschedule.aaa.activity.search.manyquestions.CustomCornerView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_above="@+id/backView"/>
        <View
            android:id="@+id/backView"
            android:background="@color/black"
            android:layout_width="match_parent"
            android:layout_height="141dp"
            android:layout_alignParentBottom="true"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="141dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true">
            <ProgressBar
                android:layout_gravity="center_vertical"
                android:id="@+id/correct_count_down_loading"
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:indeterminateDrawable="@drawable/manay_pic_search_progress_drawable"/>
            <TextView
                android:textSize="16sp"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在扫描..."
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </RelativeLayout>
    <View
        android:id="@+id/admcc_statusbar_bg"
        android:background="@drawable/c3_2"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:alpha="0"/>
    <RelativeLayout
        android:gravity="center_vertical"
        android:id="@+id/admcc_titlebar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/admcc_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="16dp"
            android:src="@drawable/icon_pic_many_search_back_b"
            android:scaleType="fitCenter"
            android:layout_centerVertical="true"/>
        <FrameLayout
            android:id="@+id/adscc_right_fl"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"/>
        <TextView
            android:textSize="12dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/admcc_recrop_guide_jump"
            android:background="@drawable/pic_many_title_guide_jump_bg"
            android:paddingLeft="12dp"
            android:paddingTop="6dp"
            android:paddingRight="10dp"
            android:paddingBottom="6dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="16dp"
            android:text="查看单题拍结果"
            android:includeFontPadding="false"
            android:drawableRight="@drawable/pic_many_title_guide_jump_arrow"
            android:drawablePadding="1dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
        <ImageView
            android:id="@+id/icon_result_guide"
            android:visibility="gone"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginRight="16dp"
            android:src="@drawable/icon_result_guide_white"
            android:scaleType="fitCenter"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <com.suda.yzune.wakeupschedule.aaa.activity.search.slide.CustomCoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/admcc_container"
            android:background="@drawable/many_search_sliding_place_bg_b"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/view_pager_bottom_sheet_behavior_b">
            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/fl_search_app_bar_layout"
                android:background="@drawable/many_search_sliding_place_bg_b"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                app:elevation="0dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <View
                        android:layout_gravity="center"
                        android:background="@drawable/search_slide_bg"
                        android:layout_width="36dp"
                        android:layout_height="4dp"/>
                </FrameLayout>
            </com.google.android.material.appbar.AppBarLayout>
            <RelativeLayout
                android:id="@+id/admcc_error_container"
                android:paddingBottom="20dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_behavior="@string/view_pager_bottom_sheet_behavior_b"/>
            <com.suda.yzune.wakeupschedule.aaa.activity.questionsearch.camera.widget.SearchResultPager
                android:layout_gravity="bottom|center_horizontal"
                android:id="@+id/search_pager"
                android:background="#ffffff"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>
        </LinearLayout>
    </com.suda.yzune.wakeupschedule.aaa.activity.search.slide.CustomCoordinatorLayout>
    <HorizontalScrollView
        android:id="@+id/title_tab_layout_scroll"
        android:visibility="gone"
        android:scrollbars="none"
        android:fadingEdgeLength="10dp"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:requiresFadingEdge="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/title_tab_layout"
            android:layout_width="match_parent"
            android:layout_height="44dp"/>
    </HorizontalScrollView>
    <RelativeLayout
        android:id="@+id/admcc_crop_guide_container"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:alpha="0">
        <View
            android:gravity="center"
            android:id="@+id/admcc_recrop_guide_button"
            android:background="@drawable/many_recrop_guide_layout_bg"
            android:layout_width="101dp"
            android:layout_height="28dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="12dp"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"/>
        <ImageView
            android:gravity="center"
            android:id="@+id/admcc_recrop_guide_close_button"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginRight="27dp"
            android:layout_marginBottom="18dp"
            android:src="@drawable/many_crop_btn_right"
            android:scaleType="center"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
</FrameLayout>
