<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.suda.yzune.wakeupschedule.widget.ShadowFrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginHorizontal="8dp"
        app:linear_bg_color="@color/white"
        app:linear_elevation_move_size="1dp"
        app:linear_round_radius="16dp"
        app:linear_shadow_color="#19000000"
        app:linear_shadow_size="8dp">
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/eas_guide_bg"
            android:paddingLeft="16dp"
            android:paddingTop="12dp"
            android:paddingRight="16dp"
            android:paddingBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <TextView
                android:textSize="14sp"
                android:textColor="#ff141414"
                android:gravity="center"
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击周数可以快速回到当前周"
                android:layout_marginEnd="12dp"/>
            <ImageView
                android:layout_gravity="center"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/guide_close"
                android:contentDescription="@null"/>
        </LinearLayout>
    </com.suda.yzune.wakeupschedule.widget.ShadowFrameLayout>
    <ImageView
        android:layout_gravity="start"
        android:layout_width="25dp"
        android:layout_height="7dp"
        android:layout_marginTop="1dp"
        android:src="@drawable/guide_arrow"
        android:contentDescription="@null"
        android:layout_marginStart="42dp"
        android:layout_marginEnd="8dp"/>
</FrameLayout>
