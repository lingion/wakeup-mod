<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:theme="@style/Theme.AppWidget.AppWidgetContainerParent"
    android:id="@android:id/background"
    android:padding="40px"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/Widget.AppWidget.AppWidget.Container">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="13dp"
            android:id="@+id/tv_schedule_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="课表"
            android:maxLines="1"
            android:maxLength="12"
            style="@style/TextAppearance.AppCompat.Medium"/>
        <TextView
            android:textSize="13dp"
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3.26"
            android:layout_marginEnd="8dp"
            android:layout_toStartOf="@+id/tv_week_count"
            style="@style/TextAppearance.AppCompat.Medium"/>
        <TextView
            android:textSize="13dp"
            android:id="@+id/tv_week_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="第1周"
            android:layout_marginEnd="8dp"
            android:layout_toStartOf="@+id/tv_week"
            style="@style/TextAppearance.AppCompat.Medium"/>
        <TextView
            android:textSize="13dp"
            android:textColor="?android:attr/colorAccent"
            android:id="@+id/tv_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="周六"
            android:layout_alignParentEnd="true"
            style="@style/TextAppearance.AppCompat.Medium"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_courses"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:layout_below="@+id/rl_title"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true">
        <RelativeLayout
            android:id="@+id/rl_course_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_indicator_0"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:src="@drawable/appwidget_bg"
                android:layout_alignTop="@+id/ll_course_0"
                android:layout_alignBottom="@+id/ll_course_0"
                android:layout_alignParentStart="true"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_course_0"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_toStartOf="@+id/ll_time_0"
                android:layout_toEndOf="@+id/iv_indicator_0">
                <TextView
                    android:textSize="13dp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:id="@+id/tv_course_name_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:singleLine="true"/>
                <LinearLayout
                    android:id="@+id/ll_detail_0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="12dp"
                        android:id="@+id/tv_location_0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:layout_marginEnd="8dp"
                        style="@style/TextAppearance.AppCompat.Medium"/>
                    <TextView
                        android:textSize="12dp"
                        android:id="@+id/tv_teacher_0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:singleLine="true"
                        style="@style/TextAppearance.AppCompat.Medium"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_time_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/ll_course_0"
                android:layout_alignBottom="@+id/ll_course_0"
                android:layout_marginStart="8dp"
                android:layout_alignParentEnd="true">
                <TextView
                    android:textSize="12dp"
                    android:typeface="monospace"
                    android:textColor="?android:attr/colorControlNormal"
                    android:id="@+id/tv_start_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:singleLine="true"/>
                <TextView
                    android:textSize="12dp"
                    android:typeface="monospace"
                    android:textColor="?android:attr/colorControlNormal"
                    android:id="@+id/tv_end_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:singleLine="true"/>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_course_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <ImageView
                android:id="@+id/iv_indicator_1"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:src="@drawable/appwidget_bg"
                android:layout_alignTop="@+id/ll_course_1"
                android:layout_alignBottom="@+id/ll_course_1"
                android:layout_alignParentStart="true"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_course_1"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_toStartOf="@+id/ll_time_1"
                android:layout_toEndOf="@+id/iv_indicator_1">
                <TextView
                    android:textSize="13dp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:id="@+id/tv_course_name_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:singleLine="true"/>
                <LinearLayout
                    android:id="@+id/ll_detail_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="12dp"
                        android:id="@+id/tv_location_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:layout_marginEnd="8dp"
                        style="@style/TextAppearance.AppCompat.Medium"/>
                    <TextView
                        android:textSize="12dp"
                        android:id="@+id/tv_teacher_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:singleLine="true"
                        style="@style/TextAppearance.AppCompat.Medium"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_time_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/ll_course_1"
                android:layout_alignBottom="@+id/ll_course_1"
                android:layout_marginStart="8dp"
                android:layout_alignParentEnd="true">
                <TextView
                    android:textSize="12dp"
                    android:typeface="monospace"
                    android:textColor="?android:attr/colorControlNormal"
                    android:id="@+id/tv_start_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:singleLine="true"/>
                <TextView
                    android:textSize="12dp"
                    android:typeface="monospace"
                    android:textColor="?android:attr/colorControlNormal"
                    android:id="@+id/tv_end_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:singleLine="true"/>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
    <TextView
        android:textSize="14dp"
        android:gravity="center"
        android:id="@android:id/empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:text="������\10数据加载中\10马上就好"
        android:layout_below="@+id/rl_title"
        android:layout_alignParentBottom="true"
        android:lineSpacingExtra="8dp"
        android:textAlignment="center"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
