<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="66dp"
    android:layout_height="66dp">
    <RelativeLayout
        android:id="@+id/rl_camera_gallery_center_right"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true">
        <com.zybang.camera.view.RotateAnimImageView
            android:id="@+id/camera_gallery_center_right"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:src="@drawable/fuse_search_camera_gallery"
            android:scaleType="centerCrop"
            android:layout_centerHorizontal="true"
            app:corner_radius="10dp"
            app:is_cover_src="true"/>
        <View
            android:id="@+id/camera_gallery_out_border_right"
            android:background="@drawable/fuse_search_round_10_bg"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="@dimen/common_text_size_n_28"
            android:textColor="@color/fuse_search_share_txt_color"
            android:gravity="center"
            android:id="@+id/camera_photos_num_center_right"
            android:background="@drawable/shape_bg_rectangle_redius3dp_color2655fe"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:layout_above="@+id/space"
            android:layout_marginStart="6dp"/>
        <Space
            android:id="@+id/space"
            android:layout_width="1dp"
            android:layout_height="6dp"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
</RelativeLayout>
