<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/id_input_root_layout"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateFrameLayout
        android:layout_gravity="center_vertical"
        android:id="@+id/search_again_error"
        android:background="@drawable/bg_common_big_buttom"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="8dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/white_FFFFFF"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_search_option_right_c"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="再拍一题"/>
    </com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateFrameLayout>
</FrameLayout>
