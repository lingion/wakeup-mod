<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/c1_8"/>
            <corners
                android:topLeftRadius="@dimen/F_Large"
                android:topRightRadius="@dimen/F_Large"/>
        </shape>
    </item>
    <item android:state_pressed="false">
        <shape>
            <solid android:color="@color/c2_1"/>
            <corners
                android:topLeftRadius="@dimen/F_Large"
                android:topRightRadius="@dimen/F_Large"/>
        </shape>
    </item>
</selector>
