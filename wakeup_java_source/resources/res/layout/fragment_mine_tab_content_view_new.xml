<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#f8f8fa"
    android:paddingBottom="44dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        android:id="@+id/mine_user_nested_scrollview"
        android:background="@android:color/transparent"
        android:scrollbars="none"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:descendantFocusability="blocksDescendants"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp">
            <com.suda.yzune.wakeupschedule.aaa.widget.MineNewUserLoginView
                android:id="@+id/mine_user_login_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bannerLayout"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <com.suda.yzune.wakeupschedule.widget.banner.Banner
                    android:id="@+id/banner"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="336:52"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/shape_solid_ffffffff_radius_16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/ll_mine_tab_content_view_new_course_setting"
                    android:layout_width="match_parent"
                    android:layout_height="52dp">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="#141414"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="课表设置"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"/>
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/icon_gray_right_arrow_20_20"
                        android:layout_marginEnd="16dp"/>
                </LinearLayout>
                <View
                    android:background="#14141414"
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/ll_mine_tab_content_view_global_setting"
                    android:layout_width="match_parent"
                    android:layout_height="52dp">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="#141414"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="全局设置"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"/>
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/icon_gray_right_arrow_20_20"
                        android:layout_marginEnd="16dp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/shape_solid_ffffffff_radius_16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/ll_mine_tab_content_view_new_help_feedback"
                    android:layout_width="match_parent"
                    android:layout_height="52dp">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="#141414"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="常见问题"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"/>
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/icon_gray_right_arrow_20_20"
                        android:layout_marginEnd="16dp"/>
                </LinearLayout>
                <View
                    android:background="#14141414"
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/ll_mine_tab_content_view_more"
                    android:layout_width="match_parent"
                    android:layout_height="52dp">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="#141414"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="更多"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"/>
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/icon_gray_right_arrow_20_20"
                        android:layout_marginEnd="16dp"/>
                </LinearLayout>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
