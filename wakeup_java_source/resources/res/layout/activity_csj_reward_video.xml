<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/id_reward_layout"
    android:background="#000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/id_csj_ad_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:background="@drawable/reward_top_background"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/reward_small"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:textSize="12dp"
                android:textColor="#f6bd4f"
                android:id="@+id/id_countdown_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <View
                android:background="#ffffff"
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="12dp"
                    android:textColor="#ffffff"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/id_video_skip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="跳过"/>
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/id_skip_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>
