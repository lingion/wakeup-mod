<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="184dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">
        <ImageView
            android:id="@+id/id_ad_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"/>
        <com.fastad.api.player.VideoPlayLayout
            android:id="@+id/id_ad_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <FrameLayout
            android:id="@+id/id_anim_layout"
            android:background="#99000000"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/id_anim_frame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14dp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:ellipsize="end"
                    android:id="@+id/id_anim_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxLines="1"/>
            </LinearLayout>
        </FrameLayout>
        <ImageView
            android:layout_gravity="end|bottom"
            android:id="@+id/id_adn_logo"
            android:layout_width="37dp"
            android:layout_height="16dp"
            android:layout_marginBottom="6dp"
            android:scaleType="fitEnd"
            android:layout_marginEnd="6dp"/>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="16dp"
        android:textColor="#141414"
        android:ellipsize="end"
        android:id="@+id/id_ad_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:maxLines="2"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <View
        android:id="@+id/id_line"
        android:background="#edeff0"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <com.homework.fastad.common.tool.AppInfoLayout
        android:id="@+id/id_app_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <TextView
        android:textSize="16dp"
        android:textColor="#141414"
        android:gravity="center"
        android:id="@+id/id_ad_click_look"
        android:background="@drawable/click_look_ad_shape"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
</LinearLayout>
