<?xml version="1.0" encoding="utf-8"?>
<com.zuoyebang.design.widget.StateLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="horizontal"
    android:id="@+id/uxc_menu_pop"
    android:layout_width="wrap_content"
    android:layout_height="44dp">
    <ImageView
        android:id="@+id/menu_icon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginRight="8dp"
        android:src="@drawable/nav_icon_share"
        android:scaleType="centerCrop"/>
    <TextView
        android:textSize="@dimen/common_text_size_n_28"
        android:textColor="@color/c1_2"
        android:id="@+id/menu_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="20dp"
        android:text="订阅"/>
</com.zuoyebang.design.widget.StateLinearLayout>
