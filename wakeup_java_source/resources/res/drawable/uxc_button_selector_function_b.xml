<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/uxc_button_radius"/>
            <solid android:color="@color/uxc_btn_bg_functionb_highlight"/>
            <stroke
                android:width="@dimen/uxc_button_boarder"
                android:color="@color/uxc_btn_boarder_functionb_highlight"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/uxc_button_radius"/>
            <solid android:color="@color/uxc_btn_bg_functionb_disable"/>
            <stroke
                android:width="@dimen/uxc_button_boarder"
                android:color="@color/uxc_btn_boarder_functionb_disable"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/uxc_button_radius"/>
            <solid android:color="@color/uxc_btn_bg_functionb_normal"/>
            <stroke
                android:width="@dimen/uxc_button_boarder"
                android:color="@color/uxc_btn_boarder_functionb_normal"/>
        </shape>
    </item>
</selector>
