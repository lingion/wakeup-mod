<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/apk/res-auto"
    android:id="@+id/content_layout"
    android:background="#00000000"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/common_ui_dialog_layout_margin"
    android:layout_marginEnd="@dimen/common_ui_dialog_layout_margin">
    <com.baidu.homework.activity.live.widget.MaxHeightScrollView
        android:id="@+id/content_message_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/content_message"
            android:text="对话框内容"
            skin:textColor="@color/skin_wz_3"
            style="@style/common_ui_dialog_content_text"/>
    </com.baidu.homework.activity.live.widget.MaxHeightScrollView>
    <EditText
        android:id="@+id/edit_text"
        android:paddingLeft="@dimen/common_ui_dialog_edit_padding"
        android:layout_width="match_parent"
        android:layout_height="@dimen/common_ui_dialog_edit_height"
        android:layout_marginTop="@dimen/common_ui_dialog_edit_margin"
        android:hint="请输入搜索内容"
        android:layout_below="@+id/content_message_layout"
        style="@style/EditTextStyles"/>
</RelativeLayout>
