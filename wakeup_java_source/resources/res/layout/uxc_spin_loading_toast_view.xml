<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/uxc_loading_msg_fl"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_centerInParent="true">
        <com.zuoyebang.design.tag.TagTextView
            android:id="@+id/uxc_util_tag_bg"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            app:tag_bg_color="@color/c1_6"
            app:tag_bind_type="solid_view"
            app:tag_corner_radius="@dimen/F_Small"/>
        <LinearLayout
            android:gravity="center"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="wrap_content"
            android:layout_height="36dp">
            <ImageView
                android:id="@+id/uxc_loading_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/uxc_spin_loaing_circle"/>
            <TextView
                android:textSize="14dp"
                android:textColor="#ffffff"
                android:ellipsize="none"
                android:gravity="center"
                android:id="@+id/iknow_alert_dialog_waiting_message"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginLeft="8dp"
                android:maxWidth="228dp"
                android:minWidth="86dp"
                android:singleLine="true"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </FrameLayout>
</merge>
