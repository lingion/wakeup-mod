<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:background="@drawable/reward_dialog_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp">
        <TextView
            android:textSize="24dp"
            android:textStyle="bold"
            android:textColor="#621200"
            android:id="@+id/id_reward_tips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:text="距离奖励很近啦"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="16dp"
            android:textColor="#621200"
            android:gravity="center"
            android:id="@+id/id_reward_second_text"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_below="@+id/id_reward_tips"
            android:layout_centerHorizontal="true"
            android:paddingHorizontal="24dp"/>
        <TextView
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@+id/id_reward_big_button"
            android:background="@drawable/reward_get_reward"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="17dp"
            android:text="继续领奖励"
            android:layout_below="@+id/id_reward_second_text"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>
        <ImageView
            android:id="@+id/id_reward_hand"
            android:visibility="gone"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_marginTop="-45dp"
            android:src="@drawable/reward_hand"
            android:layout_below="@+id/id_reward_big_button"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textSize="14dp"
            android:textColor="#626466"
            android:id="@+id/id_reward_small_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:text="放弃奖励"
            android:layout_below="@+id/id_reward_big_button"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@+id/id_reward_test"
        android:layout_width="175dp"
        android:layout_height="175dp"
        android:src="@drawable/reward_box"/>
</FrameLayout>
