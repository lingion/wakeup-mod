<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/c2_1"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:layout_width="match_parent"
    android:layout_height="64dp">
    <include
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginLeft="12dp"
        android:layout_toRightOf="@+id/test_left_img"
        android:layout_centerVertical="true"
        layout="@layout/uxc_list_singleline_list_style2_base_layout"/>
    <ImageView
        android:background="@color/c1_5"
        android:layout_width="90dp"
        android:layout_height="match_parent"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
    <ImageView
        android:id="@+id/test_left_img"
        android:background="@color/c1_4"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_toRightOf="@+id/test_left_img_ex"
        android:layout_centerVertical="true"/>
    <ImageView
        android:id="@+id/test_left_img_ex"
        android:background="@color/c1_5"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"/>
</RelativeLayout>
