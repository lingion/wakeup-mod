<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/id_splash_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"/>
    <com.fastad.api.player.VideoPlayLayout
        android:id="@+id/id_splash_video"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <com.homework.fastad.common.tool.AppInfoLayout
        android:id="@+id/id_app_download_layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="43dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:layout_toStartOf="@+id/id_skip_layout"/>
    <FrameLayout
        android:id="@+id/id_skip_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="16dp"
        android:layout_alignParentEnd="true">
        <TextView
            android:textSize="12dp"
            android:textColor="#ffffff"
            android:gravity="center"
            android:layout_gravity="end|top"
            android:id="@+id/id_skip_text"
            android:background="@drawable/splash_skip_background"
            android:layout_width="60dp"
            android:layout_height="24dp"
            android:text="跳过5s"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/id_skip_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/id_app_icon_layout"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="165dp"
        android:layout_centerHorizontal="true">
        <ImageView
            android:id="@+id/id_app_icon"
            android:layout_width="90dp"
            android:layout_height="90dp"/>
        <TextView
            android:textSize="20dp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:ellipsize="end"
            android:id="@+id/id_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:shadowColor="#66000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"/>
        <TextView
            android:textSize="14dp"
            android:textColor="#ffffff"
            android:ellipsize="end"
            android:id="@+id/id_ad_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:shadowColor="#66000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/id_hor_layout"
        android:background="#ffffff"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="235dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <FrameLayout
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="194dp">
            <ImageView
                android:id="@+id/id_hor_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"/>
            <com.fastad.api.player.VideoPlayLayout
                android:id="@+id/id_hor_video"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </FrameLayout>
        <TextView
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="#141414"
            android:ellipsize="end"
            android:id="@+id/id_hor_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"/>
        <TextView
            android:textSize="12dp"
            android:textColor="#141414"
            android:ellipsize="end"
            android:id="@+id/id_hor_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"/>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/id_splash_slide_background"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.fastad.api.widget.ArcView
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/id_ad_splash_slide_anime"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="120dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true">
            <ImageView
                android:id="@+id/id_ad_slide_gif"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/reward_small"/>
            <TextView
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="轻划试试"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/id_anim_layout"
        android:paddingBottom="140dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">
        <ImageView
            android:id="@+id/id_anim_frame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="16dp"
            android:textColor="#ffffff"
            android:ellipsize="end"
            android:id="@+id/id_anim_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:shadowColor="#3d000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"/>
        <TextView
            android:textSize="12dp"
            android:textColor="#ffffff"
            android:ellipsize="end"
            android:id="@+id/id_anim_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:shadowColor="#3d000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/id_open_ad_layout"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="80dp"
        android:layout_alignParentBottom="true">
        <View
            android:layout_gravity="center"
            android:id="@+id/id_open_ad_anim"
            android:background="@drawable/splash_open_ad_anim"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <View
            android:layout_gravity="center"
            android:id="@+id/id_open_ad_anim_1"
            android:background="@drawable/splash_open_ad_anim"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/id_open_ad_text_layout"
            android:background="@drawable/splash_open_ad_background"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="42dp"
            android:layout_marginEnd="42dp">
            <TextView
                android:textSize="16dp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/id_open_ad_text_true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="跳转详情或第三方应用"/>
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/splash_open_ad_icon"/>
        </LinearLayout>
    </FrameLayout>
    <ImageView
        android:id="@+id/id_adn_logo"
        android:layout_width="37dp"
        android:layout_height="16dp"
        android:layout_marginBottom="16dp"
        android:scaleType="fitStart"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="16dp"/>
</RelativeLayout>
