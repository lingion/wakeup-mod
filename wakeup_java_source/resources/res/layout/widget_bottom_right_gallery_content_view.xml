<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="66dp"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/rl_camera_gallery_right"
        android:visibility="visible"
        android:layout_width="53dp"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true">
        <com.zybang.camera.view.RotateAnimImageView
            android:id="@+id/camera_gallery_right"
            android:layout_width="@dimen/camera_gallery_width"
            android:layout_height="@dimen/camera_gallery_width"
            android:layout_marginTop="6.5dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/fuse_search_camera_gallery"
            android:scaleType="centerCrop"
            android:layout_centerHorizontal="true"
            app:corner_radius="10dp"
            app:is_cover_src="true"/>
        <View
            android:id="@+id/camera_gallery_out_border_right"
            android:background="@drawable/fuse_search_round_10_bg"
            android:layout_width="@dimen/camera_gallery_width"
            android:layout_height="@dimen/camera_gallery_width"
            android:layout_marginTop="6.5dp"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="@dimen/common_text_size_n_20"
            android:textStyle="bold"
            android:textColor="@color/fuse_search_inspect_txt_color"
            android:gravity="center"
            android:layout_gravity="top|right"
            android:id="@+id/camera_photos_num_right"
            android:background="@drawable/fuse_search_main_color_gradual_change_bg"
            android:visibility="gone"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="14sp"
        android:gravity="center"
        android:id="@+id/sdk_go_check_text_right"
        android:background="@drawable/fuse_search_main_color_gradual_change_bg"
        android:layout_width="66dp"
        android:layout_height="28dp"
        android:layout_marginTop="34.5dp"
        android:text="下一步"
        style="@style/multi_check_text_style"/>
</RelativeLayout>
