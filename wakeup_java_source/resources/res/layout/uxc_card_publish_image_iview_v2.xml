<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/user_publish_image_ll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/rv_ll_row_one"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.zuoyebang.design.widget.RoundRecyclingImageView
            android:id="@+id/recycleimageview_one"
            android:layout_width="match_parent"
            android:layout_height="90.5dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"
            app:corner_top_left_radius="8dp"/>
        <com.zuoyebang.design.widget.RoundRecyclingImageView
            android:id="@+id/recycleimageview_two"
            android:layout_width="match_parent"
            android:layout_height="106.5dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"/>
        <com.zuoyebang.design.widget.RoundRecyclingImageView
            android:id="@+id/recycleimageview_three"
            android:layout_width="match_parent"
            android:layout_height="106.5dp"
            android:layout_weight="1"
            app:corner_top_right_radius="8dp"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/rv_ll_row_two"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.zuoyebang.design.widget.RoundRecyclingImageView
            android:id="@+id/recycleimageview_four"
            android:layout_width="match_parent"
            android:layout_height="106.5dp"
            android:layout_marginTop="4dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"
            app:corner_bottom_left_radius="8dp"/>
        <com.zuoyebang.design.widget.RoundRecyclingImageView
            android:id="@+id/recycleimageview_five"
            android:layout_width="match_parent"
            android:layout_height="106.5dp"
            android:layout_marginTop="4dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"/>
        <com.zuoyebang.design.widget.RoundRecyclingImageView
            android:id="@+id/recycleimageview_six"
            android:layout_width="match_parent"
            android:layout_height="106.5dp"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            app:corner_bottom_right_radius="8dp"/>
    </LinearLayout>
    <com.zuoyebang.design.widget.RoundRecyclingImageView
        android:id="@+id/supiei_big_image_one"
        android:visibility="gone"
        android:layout_width="215dp"
        android:layout_height="215dp"
        android:layout_marginRight="4dp"
        android:scaleType="centerCrop"
        android:layout_weight="1"
        app:corner_bottom_left_radius="8dp"
        app:corner_top_left_radius="8dp"/>
</LinearLayout>
