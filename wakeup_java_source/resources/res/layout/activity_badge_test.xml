<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/img"
        android:background="@color/wz_1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/img1"
        android:background="@color/wz_1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/img2"
        android:background="@color/wz_1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/img3"
        android:background="@color/wz_1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/img4"
        android:background="@color/wz_1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/img5"
        android:background="@color/wz_1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"/>
    <com.zuoyebang.design.badge.BadgeTextView
        android:id="@+id/img6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:badge_bind_type="badge_point"/>
    <com.zuoyebang.design.badge.BadgeTextView
        android:id="@+id/img7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:badge_bind_type="badge_num"/>
    <com.zuoyebang.design.badge.BadgeTextView
        android:id="@+id/img8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:badge_bind_type="badge_text"/>
    <com.zuoyebang.design.badge.BadgeTextView
        android:id="@+id/img9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"/>
</LinearLayout>
