<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="horizontal"
    android:id="@+id/follow_add_user_ll"
    android:visibility="visible"
    android:layout_width="54dp"
    android:layout_height="24dp">
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/add_icon"
        android:visibility="visible"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginRight="2dp"
        android:src="@drawable/uxc_card_follow_add_v2"/>
    <ProgressBar
        android:layout_gravity="center"
        android:id="@+id/follow_icon_ing"
        android:visibility="gone"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginRight="2dp"
        android:indeterminate="true"
        android:indeterminateDrawable="@drawable/uxc_follow_progressbar_v2"/>
    <TextView
        android:textSize="12dp"
        android:textColor="@color/f_1"
        android:layout_gravity="center"
        android:id="@+id/add_tips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="关注"/>
</LinearLayout>
