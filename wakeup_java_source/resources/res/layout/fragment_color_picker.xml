<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layout_width="280dp"
    android:layout_height="wrap_content">
    <com.google.android.material.textview.MaterialTextView
        android:textStyle="bold"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="选择颜色"/>
    <com.suda.yzune.wakeupschedule.widget.colorpicker.ColorPickerView
        android:id="@+id/cpv_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cpv_alphaChannelVisible="true"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <View
            android:layout_gravity="center"
            android:id="@+id/v_color"
            android:background="?attr/colorSecondary"
            android:layout_width="72dp"
            android:layout_height="32dp"/>
        <com.google.android.material.textview.MaterialTextView
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#"
            android:layout_marginStart="24dp"/>
        <com.google.android.material.textfield.TextInputEditText
            android:typeface="monospace"
            android:id="@+id/et_color"
            android:focusable="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:singleLine="true"
            android:maxLength="8"
            android:digits="0123456789ABCDEFabcdef"
            android:layout_weight="1"
            android:inputType="textNoSuggestions"
            android:imeOptions="actionGo"
            style="@style/ThemeOverlay.Material3.TextInputEditText.OutlinedBox"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:text="取消"
            android:layout_weight="1"
            style="@style/DialogButtonStyle"/>
        <com.google.android.material.button.MaterialButton
            android:textStyle="bold"
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:text="保存"
            android:layout_weight="1"
            style="@style/DialogButtonStyle"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
