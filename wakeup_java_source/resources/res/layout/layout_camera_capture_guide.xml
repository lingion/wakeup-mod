<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/capture_guide_layout"
    android:background="#7a000000"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toTopOf="@+id/fl_camera_control_top">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/ll_capture_btn_cover"
        android:background="@drawable/sdk_bg_doc_scan_guide_dialog"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="visible"
        android:layout_width="67dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="70dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <ImageView
            android:visibility="visible"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/icon_camera_capture_guide_icon_black"
            android:scaleType="fitXY"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="11sp"
            android:textColor="#000000"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="悬浮窗搜题"
            android:layout_centerHorizontal="true"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/ivArrowCaptureGuide"
        android:background="@drawable/icon_camera_capture_guide_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="85dp"
        app:layout_constraintBottom_toTopOf="@+id/ll_capture_btn_cover"
        app:layout_constraintStart_toStartOf="parent"/>
    <com.suda.yzune.wakeupschedule.aaa.widget.SecureLottieAnimationView
        android:id="@+id/ivCaptureMainView"
        android:background="@drawable/shape_solid_e2e5eb_radius_top_12dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginLeft="50dp"
        android:layout_marginRight="50dp"
        android:layout_marginBottom="100dp"
        android:layout_below="@+id/ivArrowCaptureGuide"
        android:layout_centerHorizontal="true"
        app:layout_constraintBottom_toTopOf="@+id/ivArrowCaptureGuide"
        app:layout_constraintDimensionRatio="328:350"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>
    <ImageView
        android:id="@+id/iv_close"
        android:background="@drawable/common_share_dialog_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp"
        app:layout_constraintRight_toRightOf="@+id/ivCaptureMainView"
        app:layout_constraintTop_toTopOf="@+id/ivCaptureMainView"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/shape_solid_ffffff_bottom_radius_12dp"
        android:layout_width="0dp"
        android:layout_height="70dp"
        app:layout_constraintLeft_toLeftOf="@+id/ivCaptureMainView"
        app:layout_constraintRight_toRightOf="@+id/ivCaptureMainView"
        app:layout_constraintTop_toBottomOf="@+id/ivCaptureMainView">
        <TextView
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@+id/tv_open_capture"
            android:background="@drawable/shape_rectangle_2655fe_radius_8dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="18dp"
            android:text="立即设置"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
