<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:paddingBottom="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/dialog_drag_course_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp">
        <TextView
            android:textSize="13sp"
            android:textColor="#ffb9babd"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:text="此更改应用范围？"/>
        <View
            android:background="#fff0f0f0"
            android:layout_width="wrap_content"
            android:layout_height="0.5dp"/>
        <TextView
            android:textSize="15sp"
            android:textColor="#ff141414"
            android:gravity="center"
            android:id="@+id/updateCurrentWeekCourse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:text="针对本周课程生效"/>
        <View
            android:background="#fff0f0f0"
            android:layout_width="wrap_content"
            android:layout_height="0.5dp"/>
        <TextView
            android:textSize="15sp"
            android:textColor="#ff141414"
            android:gravity="center"
            android:id="@+id/updateAllCourse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:text="针对以后全部课程生效"/>
    </LinearLayout>
    <TextView
        android:textSize="15sp"
        android:textColor="#ffff4b4b"
        android:gravity="center"
        android:id="@+id/cannel"
        android:background="@drawable/dialog_drag_course_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="16dp"
        android:minHeight="52dp"
        android:text="取消"/>
</LinearLayout>
