<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/login_hint_dialog_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="14sp"
        android:textColor="#ff555966"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:includeFontPadding="false"/>
    <TextView
        android:textSize="22sp"
        android:textColor="#ff1b1e29"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/tv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"/>
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="36dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="20dp">
        <com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateButton
            android:textSize="16sp"
            android:textColor="#ff1b1e29"
            android:gravity="center"
            android:id="@+id/btn_cancel"
            android:background="@drawable/login_hint_dialog_cancel_background"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginRight="10dp"
            android:layout_weight="1"/>
        <com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateButton
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@+id/btn_confirm"
            android:background="@drawable/login_next_button_shape"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
