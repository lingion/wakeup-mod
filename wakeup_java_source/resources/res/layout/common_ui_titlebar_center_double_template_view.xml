<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:orientation="horizontal"
    android:background="@drawable/common_ui_titlebar_tab_blue_trans_round_5"
    android:layout_width="124dp"
    android:layout_height="32dp"
    android:layout_margin="8dp"
    android:paddingStart="2dp"
    android:paddingEnd="2dp">
    <FrameLayout
        android:layout_gravity="center_vertical"
        android:id="@+id/switch_animation_view"
        android:background="@drawable/uxc_tab_button_shape_bg"
        android:layout_width="60dp"
        android:layout_height="28dp"/>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="28dp">
        <RelativeLayout
            android:id="@+id/bottom_left_layout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:shadowColor="#e0c4c8cc"
            android:shadowDy="3"
            android:layout_weight="1">
            <TextView
                android:textSize="@dimen/uxc_font_size_14"
                android:textStyle="bold"
                android:textColor="@color/c1_2"
                android:id="@+id/button_left_text"
                android:duplicateParentState="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选课"
                android:layout_centerInParent="true"/>
            <View
                android:id="@+id/left_message_unread_dot"
                android:background="@drawable/common_ui_titlebar_btn_unread_dot"
                android:visibility="gone"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginBottom="-3dp"
                android:layout_toRightOf="@+id/button_left_text"
                android:layout_above="@+id/button_left_text"/>
            <TextView
                android:textSize="9dp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/message_unread_num"
                android:background="@drawable/common_ui_titlebar_tab_index_num_bg"
                android:paddingLeft="3dp"
                android:paddingRight="3dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="11dp"
                android:layout_marginRight="8dp"
                android:layout_marginBottom="-6dp"
                android:minWidth="11dp"
                android:minHeight="11dp"
                android:text="99+"
                android:singleLine="true"
                android:includeFontPadding="false"
                android:layout_above="@+id/button_left_text"
                android:layout_alignParentRight="true"
                android:lineSpacingExtra="0dp"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/bottom_right_layout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:layout_weight="1">
            <TextView
                android:textSize="@dimen/uxc_font_size_14"
                android:textColor="@color/c1_2"
                android:id="@+id/button_right_text"
                android:duplicateParentState="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上课"
                android:layout_centerInParent="true"/>
            <View
                android:id="@+id/right_info_unread_dot"
                android:background="@drawable/common_ui_titlebar_btn_unread_dot"
                android:visibility="gone"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginBottom="-3dp"
                android:layout_toRightOf="@+id/button_right_text"
                android:layout_above="@+id/button_right_text"/>
        </RelativeLayout>
    </LinearLayout>
</FrameLayout>
