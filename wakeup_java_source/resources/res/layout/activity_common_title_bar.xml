<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/title_bar"
    android:background="@color/title_bar_bg"
    android:layout_width="match_parent"
    android:layout_height="@dimen/common_title_bar_height">
    <com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateImageView
        android:id="@+id/title_left_btn"
        android:background="@null"
        android:paddingLeft="16dp"
        android:paddingRight="25dp"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/icon_text_search_title_black_back"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:onClick="onLeftButtonClicked"
        android:contentDescription="@null"/>
    <FrameLayout
        android:id="@+id/titleLayout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:maxWidth="210dp"
        android:layout_centerInParent="true"
        android:layout_centerVertical="true">
        <TextView
            android:textSize="@dimen/common_text_size_23"
            android:textStyle="bold"
            android:textColor="@color/wz_2"
            android:ellipsize="end"
            android:layout_gravity="center"
            android:id="@+id/title_name"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="210dp"
            android:singleLine="true"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="1"/>
    </FrameLayout>
    <ImageButton
        android:id="@+id/title_right_view"
        android:background="#00000000"
        android:paddingLeft="15dp"
        android:paddingRight="18dp"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:scaleType="centerInside"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:onClick="onRightButtonClicked"/>
    <com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateTextColorView
        android:textSize="@dimen/common_text_size_n_28"
        android:textColor="@color/wz_4"
        android:gravity="center_vertical"
        android:id="@+id/title_right_tv"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:scaleType="centerInside"
        android:text="举报"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:onClick="onRightButtonClicked"/>
    <View
        android:id="@+id/title_line"
        android:background="@color/default_line_color"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
