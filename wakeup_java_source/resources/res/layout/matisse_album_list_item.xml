<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/album_item_height">
    <ImageView
        android:id="@+id/album_cover"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginLeft="16dp"
        android:scaleType="centerCrop"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"/>
    <TextView
        android:textSize="14sp"
        android:textColor="?attr/album.dropdown.title.color"
        android:ellipsize="end"
        android:id="@+id/album_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:maxLines="1"
        android:layout_toRightOf="@+id/album_cover"
        android:layout_centerVertical="true"
        android:layout_marginStart="8dp"/>
    <TextView
        android:textSize="14sp"
        android:textColor="?attr/album.dropdown.title.color"
        android:ellipsize="end"
        android:id="@+id/album_media_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:layout_toRightOf="@+id/album_name"
        android:layout_alignBottom="@+id/album_name"/>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="15dp"
        android:src="@drawable/ic_item_arrow"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
</RelativeLayout>
