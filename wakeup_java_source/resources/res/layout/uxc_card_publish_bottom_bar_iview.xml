<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/uxc_user_publish_bar_ll"
    android:background="@color/c2_1"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/div"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <FrameLayout
        android:orientation="vertical"
        android:id="@+id/uxc_user_publish_bar_fl"
        android:layout_width="match_parent"
        android:layout_height="56dp">
        <TextView
            android:textSize="12dp"
            android:textColor="@color/c1_4"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/uxc_item_comment"
            android:paddingLeft="100dp"
            android:paddingRight="100dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="11"
            android:drawableLeft="@drawable/uxc_card_item_comment"
            android:layout_below="@+id/div"
            android:layout_centerHorizontal="true"/>
        <com.zuoyebang.design.card.InputCollectView
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/uxc_item_collect"
            android:paddingLeft="24dp"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            layout="@layout/uxc_card_input_item_view"/>
        <com.zuoyebang.design.card.InputLikeView
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/uxc_item_like"
            android:paddingLeft="35dp"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            layout="@layout/uxc_card_input_item_view"/>
    </FrameLayout>
    <View
        android:id="@+id/div_5"
        android:background="#fff7f7f7"
        android:layout_width="match_parent"
        android:layout_height="6dp"/>
</LinearLayout>
