<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="bottom"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:id="@+id/ll_next_dialog"
        android:background="@drawable/bg_solid_white_radius_top_16"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp">
            <ImageView
                android:id="@+id/iv_next_dialog_close"
                android:padding="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_nps_dialog_close"
                android:layout_alignParentEnd="true"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#141414"
                android:id="@+id/tv_next_ask_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="内容举报"
                android:layout_centerInParent="true"
                android:layout_marginStart="16dp"/>
            <ImageView
                android:id="@+id/iv_next_dialog_back"
                android:padding="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/report_back_icon"/>
        </RelativeLayout>
        <ScrollView
            android:id="@+id/sv_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginStart="16dp">
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#141414"
                        android:id="@+id/tv_next_module_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="请选择举报原因（必填）"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_next_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp"
                    android:choiceMode="multipleChoice"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginStart="16dp">
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#141414"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="问题描述"/>
                </LinearLayout>
                <FrameLayout
                    android:background="@drawable/bg_solid_f7f9fa_radius_16"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:layout_marginTop="22dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp">
                    <EditText
                        android:textSize="14sp"
                        android:textColor="#141414"
                        android:textColorHint="#ff9da0a3"
                        android:gravity="top"
                        android:layout_gravity="start|top"
                        android:id="@+id/et_next_advice"
                        android:background="@android:color/transparent"
                        android:layout_width="match_parent"
                        android:layout_height="75dp"
                        android:layout_marginTop="12dp"
                        android:hint="请输入具体的举报理由"
                        android:maxLength="100"
                        android:inputType="textMultiLine"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#c4c8cc"
                        android:gravity="center"
                        android:layout_gravity="end|bottom"
                        android:id="@+id/tv_next_advice_max"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="0/100"
                        android:layout_marginEnd="16dp"/>
                </FrameLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginStart="16dp">
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#141414"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="联系方式"/>
                </LinearLayout>
                <FrameLayout
                    android:background="@drawable/bg_solid_f7f9fa_radius_16"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp">
                    <EditText
                        android:textSize="15sp"
                        android:textColor="#141414"
                        android:textColorHint="#ff9da0a3"
                        android:layout_gravity="center"
                        android:id="@+id/et_next_phone"
                        android:background="@android:color/transparent"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:hint="请输入手机号码或QQ号"
                        android:inputType="phone"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"/>
                </FrameLayout>
            </LinearLayout>
        </ScrollView>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#141414"
            android:gravity="center"
            android:id="@+id/stv_submit"
            android:background="@drawable/selector_feed_back_submit"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="16dp"
            android:text="提交反馈"/>
    </LinearLayout>
</FrameLayout>
