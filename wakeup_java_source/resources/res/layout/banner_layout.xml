<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:id="@+id/id_ad_image_layout"
            android:layout_width="104dp"
            android:layout_height="78dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            app:cardBackgroundColor="#ffffff"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/id_ad_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
            <com.fastad.api.player.VideoPlayLayout
                android:id="@+id/id_ad_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </androidx.cardview.widget.CardView>
        <TextView
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="#141414"
            android:ellipsize="end"
            android:id="@+id/id_ad_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_alignTop="@+id/id_ad_image_layout"
            android:layout_marginEnd="16dp"
            android:layout_toEndOf="@+id/id_ad_image_layout"/>
        <TextView
            android:textSize="12dp"
            android:textColor="#626466"
            android:ellipsize="end"
            android:id="@+id/id_ad_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:maxLines="1"
            android:layout_below="@+id/id_ad_title"
            android:layout_marginEnd="16dp"
            android:layout_toEndOf="@+id/id_ad_image_layout"/>
        <ImageView
            android:id="@+id/id_adn_icon"
            android:layout_width="37dp"
            android:layout_height="16dp"
            android:scaleType="fitStart"
            android:layout_alignBottom="@+id/id_ad_image_layout"
            android:layout_toEndOf="@+id/id_ad_image_layout"/>
        <TextView
            android:textSize="12dp"
            android:textColor="#141414"
            android:gravity="center"
            android:id="@+id/id_ad_click_look"
            android:background="@drawable/click_look_ad_shape"
            android:layout_width="72dp"
            android:layout_height="24dp"
            android:layout_alignBottom="@+id/id_ad_image_layout"
            android:layout_marginEnd="16dp"
            android:layout_alignParentEnd="true"/>
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:layout_marginEnd="9dp"
            android:layout_alignParentEnd="true">
            <ImageView
                android:layout_gravity="end|top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/gray_close_ad"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/id_ad_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </FrameLayout>
    </RelativeLayout>
    <View
        android:id="@+id/id_banner_line"
        android:background="#edeff0"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <com.homework.fastad.common.tool.AppInfoLayout
        android:id="@+id/id_banner_app_info"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
</LinearLayout>
