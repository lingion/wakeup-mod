<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:theme="@style/Theme.AppWidget.AppWidgetContainerParent"
    android:id="@android:id/background"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/Widget.AppWidget.AppWidget.Container">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="13dp"
            android:id="@+id/tv_schedule_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="课表"
            android:maxLines="1"
            android:maxLength="12"
            style="@style/TextAppearance.AppCompat.Medium"/>
        <TextView
            android:textSize="13dp"
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3.26"
            android:layout_marginEnd="8dp"
            android:layout_toStartOf="@+id/tv_week_count"
            style="@style/TextAppearance.AppCompat.Medium"/>
        <TextView
            android:textSize="13dp"
            android:id="@+id/tv_week_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="第1周"
            android:layout_marginEnd="8dp"
            android:layout_toStartOf="@+id/tv_week"
            style="@style/TextAppearance.AppCompat.Medium"/>
        <TextView
            android:textSize="13dp"
            android:textColor="?android:attr/colorAccent"
            android:id="@+id/tv_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="周六"
            android:layout_alignParentEnd="true"
            style="@style/TextAppearance.AppCompat.Medium"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_below="@+id/rl_title">
        <TextView
            android:textSize="12dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="今天"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:textSize="12dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="明天"
            android:layout_weight="1"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="4dp"
        android:layout_below="@+id/ll_title">
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ListView
                android:id="@+id/lv_course"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="#00000000"
                android:dividerHeight="8dp"/>
            <TextView
                android:textSize="14dp"
                android:gravity="center"
                android:id="@+id/empty"
                android:padding="8dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="������\10请去系统设置允许 App 后台运行和自启哦"
                android:lineSpacingExtra="8dp"
                android:textAlignment="center"/>
        </FrameLayout>
        <LinearLayout
            android:background="?android:attr/textColorSecondary"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:alpha="0.5"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ListView
                android:id="@+id/lv_course_next_day"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="#00000000"
                android:dividerHeight="8dp"/>
            <TextView
                android:textSize="14dp"
                android:gravity="center"
                android:id="@+id/empty_next_day"
                android:padding="8dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="������\10请去系统设置允许 App 后台运行和自启哦"
                android:lineSpacingExtra="8dp"
                android:textAlignment="center"/>
        </FrameLayout>
    </LinearLayout>
</RelativeLayout>
