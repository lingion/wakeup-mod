<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/shape_solid_ffffffff_left_right_radius_12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="16dp"
        android:textColor="@color/black_1B1E29"
        android:gravity="center"
        android:id="@+id/downLoadPic"
        android:padding="18dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/showmultiPicture_downLoad_icon"/>
    <View
        android:background="#f7f9fa"
        android:layout_width="match_parent"
        android:layout_height="6dp"/>
    <TextView
        android:textSize="16dp"
        android:textColor="#626466"
        android:gravity="center"
        android:id="@+id/cancleDownload"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/showmultiPicture_cancle_icon"/>
</LinearLayout>
