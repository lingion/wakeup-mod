<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.zuoyebang.design.tag.TagTextView
        android:id="@+id/tag_title_left_second_tv"
        android:layout_width="wrap_content"
        android:layout_height="18dp"
        android:layout_marginRight="8dp"/>
    <com.zuoyebang.design.tag.TagTextView
        android:id="@+id/tag_title_left_first_tv"
        android:layout_width="wrap_content"
        android:layout_height="18dp"
        android:layout_marginRight="8dp"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/c1_1"
        android:ellipsize="end"
        android:id="@+id/ls_title_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="用户ID"
        android:singleLine="true"
        android:includeFontPadding="false"
        android:layout_centerVertical="true"/>
    <com.zuoyebang.design.tag.TagTextView
        android:id="@+id/tag_title_right_first_tv"
        android:layout_width="wrap_content"
        android:layout_height="18dp"
        android:layout_marginLeft="8dp"/>
    <com.zuoyebang.design.tag.TagTextView
        android:id="@+id/tag_title_right_second_tv"
        android:layout_width="wrap_content"
        android:layout_height="18dp"
        android:layout_marginLeft="8dp"/>
</LinearLayout>
