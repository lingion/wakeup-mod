<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:scrollbars="none"
        android:fadingEdge="none"
        android:fadingEdgeLength="0dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:requiresFadingEdge="none">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="12sp"
                android:textColor="#ff626466"
                android:layout_gravity="center_horizontal"
                android:id="@+id/tv_login_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="92dp"
                android:text="验证码已发送至"
                android:includeFontPadding="false"
                android:layout_centerHorizontal="true"/>
            <com.suda.yzune.wakeupschedule.aaa.widget.FontTextView
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#141414"
                android:layout_gravity="center_horizontal"
                android:id="@+id/tv_login_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="18511111111"
                android:layout_centerHorizontal="true"
                app:fontPath="fonts/phone.ttf"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_verification_code_login"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="57dp">
                <com.suda.yzune.wakeupschedule.aaa.widget.SecurityCodeView
                    android:id="@+id/security_code_view"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"/>
                <com.suda.yzune.wakeupschedule.aaa.widget.VerificationCodeView
                    android:textSize="12sp"
                    android:textColor="@color/login_verification_code_button_text_color"
                    android:gravity="end"
                    android:id="@+id/verification_code"
                    android:background="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="获取验证码"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/common_title_bar_height">
        <com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateLinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/sll_back"
            android:paddingLeft="16dp"
            android:paddingRight="25dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentLeft="true"
            android:layout_centerInParent="true">
            <ImageView
                android:layout_gravity="center"
                android:background="@drawable/icon_text_search_title_black_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateLinearLayout>
    </RelativeLayout>
</FrameLayout>
