<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:theme="@style/Theme.AppWidget.AppWidgetContainerParent"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/Widget.AppWidget.AppWidget.Container">
    <RelativeLayout
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/rl_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="12dp"
                android:id="@+id/tv_schedule_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="课表"
                android:maxLines="1"
                android:maxLength="12"
                style="@style/TextAppearance.AppCompat.Medium"/>
            <TextView
                android:textSize="12dp"
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3.26"
                android:layout_marginEnd="4dp"
                android:layout_toStartOf="@+id/tv_week"
                style="@style/TextAppearance.AppCompat.Medium"/>
            <TextView
                android:textSize="12dp"
                android:textColor="?android:attr/colorAccent"
                android:id="@+id/tv_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周六"
                android:layout_alignParentEnd="true"
                style="@style/TextAppearance.AppCompat.Medium"/>
        </RelativeLayout>
        <ListView
            android:id="@+id/lv_course"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:divider="#00000000"
            android:dividerHeight="10dp"
            android:layout_below="@+id/rl_title"/>
        <TextView
            android:textSize="14dp"
            android:gravity="center"
            android:id="@android:id/empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:text="������\10请去系统设置允许 App 后台运行和自启哦"
            android:layout_below="@+id/rl_title"
            android:layout_alignParentBottom="true"
            android:lineSpacingExtra="8dp"
            android:textAlignment="center"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <FrameLayout
        android:theme="@style/Theme.AppWidget.AppWidgetContainerParent"
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/fl_course_left_count"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_alignParentBottom="true"
        style="@style/Widget.AppWidget.AppWidget.Container">
        <TextView
            android:textSize="13sp"
            android:textColor="#ff87888a"
            android:layout_gravity="center"
            android:id="@+id/tv_course_left_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableRight="@drawable/ic_widget_course_left_count"
            android:drawablePadding="2dp"/>
    </FrameLayout>
</RelativeLayout>
