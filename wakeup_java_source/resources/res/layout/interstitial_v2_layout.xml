<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#22000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.homework.fastad.common.tool.AppInfoLayout
        android:id="@+id/id_app_info"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <FrameLayout
        android:id="@+id/id_content_layout"
        android:background="@drawable/white_item_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:layout_marginBottom="45dp"
        android:layout_centerInParent="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="28dp">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/id_ad_owner_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp">
                <ImageView
                    android:id="@+id/id_ad_owner_logo"
                    android:layout_width="82dp"
                    android:layout_height="82dp"/>
                <TextView
                    android:textSize="20dp"
                    android:textColor="#141414"
                    android:ellipsize="end"
                    android:id="@+id/id_ad_owner_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:maxLines="1"/>
                <RatingBar
                    android:id="@+id/id_ad_owner_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="25dp"
                    android:layout_marginTop="8dp"
                    android:progressDrawable="@drawable/app_rate_progress"
                    android:numStars="5"
                    android:rating="3"
                    android:stepSize="1"
                    android:isIndicator="true"/>
                <TextView
                    android:textSize="14dp"
                    android:textColor="#141414"
                    android:ellipsize="end"
                    android:id="@+id/id_ad_owner_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:maxLines="1"/>
            </LinearLayout>
            <androidx.cardview.widget.CardView
                android:id="@+id/id_ad_material"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="32dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="#ffffff"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/id_ad_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>
                <com.fastad.api.player.VideoPlayLayout
                    android:id="@+id/id_ad_video"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </androidx.cardview.widget.CardView>
            <FrameLayout
                android:id="@+id/id_ad_click_look"
                android:background="@drawable/click_look_ad_shape"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/id_ad_shake"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="25dp"/>
                <TextView
                    android:textSize="16dp"
                    android:textStyle="bold"
                    android:textColor="#141414"
                    android:layout_gravity="center"
                    android:id="@+id/id_ad_look_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
        </LinearLayout>
        <FrameLayout
            android:layout_gravity="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp">
            <ImageView
                android:layout_gravity="end|top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/black_close_ad"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/id_ad_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </FrameLayout>
    </FrameLayout>
    <ImageView
        android:id="@+id/id_adn_logo"
        android:layout_width="37dp"
        android:layout_height="16dp"
        android:layout_marginBottom="16dp"
        android:scaleType="fitEnd"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="16dp"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
