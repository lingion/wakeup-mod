<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mine_user_login_root_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/rl_head_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/riv_avatar"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginTop="47dp"
            android:src="@drawable/ic_mine_head_avatar"
            android:layout_centerHorizontal="true"
            app:is_circle="true"/>
        <RelativeLayout
            android:id="@+id/username_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_below="@+id/riv_avatar">
            <TextView
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1b1e29"
                android:ellipsize="end"
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="立即登录"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_centerHorizontal="true"/>
            <com.suda.yzune.wakeupschedule.aaa.widget.FontTextView
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1b1e29"
                android:ellipsize="end"
                android:id="@+id/tv_user_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11111111"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_centerHorizontal="true"
                app:fontPath="fonts/phone.ttf"/>
        </RelativeLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="#87888a"
            android:ellipsize="end"
            android:id="@+id/tv_join_guide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="登录体验更多学习功能"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:layout_below="@+id/username_layout"
            android:layout_centerHorizontal="true"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/schoolAndGradeLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_below="@+id/username_layout"
            android:layout_centerHorizontal="true">
            <TextView
                android:textSize="14sp"
                android:textColor="#ff87888a"
                android:ellipsize="end"
                android:id="@+id/schoolName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="110dp"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:maxLength="8"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#ff87888a"
                android:ellipsize="end"
                android:id="@+id/gradeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:includeFontPadding="false"/>
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/user_info_arrow"
                android:contentDescription="@null"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
