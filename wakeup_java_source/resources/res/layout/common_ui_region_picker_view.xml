<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/coordinator"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.zuoyebang.design.title.CommonTitleBar
            android:id="@+id/title_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/common_title_bar_height"
            app:titleBarColor="@android:color/transparent"/>
        <RelativeLayout
            android:background="@android:color/white"
            android:paddingLeft="8dp"
            android:layout_width="match_parent"
            android:layout_height="44dp">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/choose_tab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/province_tv"
                    android:text="请选择"
                    style="@style/tab"/>
                <TextView
                    android:id="@+id/city_tv"
                    style="@style/tab"/>
                <TextView
                    android:id="@+id/area_tv"
                    style="@style/tab"/>
            </LinearLayout>
            <View
                android:id="@+id/selected_line"
                android:background="@drawable/common_ui_region_picker_bg_round"
                android:layout_width="12dp"
                android:layout_height="2dp"
                android:layout_marginBottom="4dp"
                android:layout_below="@+id/choose_tab"/>
        </RelativeLayout>
        <View
            android:layout_width="match_parent"
            style="@style/DividerBottom"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/optionspicker"
            android:background="@color/c2_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.baidu.homework.common.ui.list.CustomRecyclerView
                android:id="@+id/province_listview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"/>
            <com.baidu.homework.common.ui.list.CustomRecyclerView
                android:id="@+id/city_listview"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"/>
            <com.baidu.homework.common.ui.list.CustomRecyclerView
                android:id="@+id/district_listview"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"/>
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
