<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#ff141414"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="88dp"
        android:layout_marginRight="145dp"
        android:minHeight="88dp"
        android:text="感谢您信任\10并使用WakeUp课程表"
        android:maxLines="2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ScrollView
        android:theme="@style/PrivacyScrollView"
        android:id="@+id/sv_content"
        android:background="@drawable/shape_corner82"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="28dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toTopOf="@+id/flButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/sll_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="18dp">
            <TextView
                android:textSize="14sp"
                android:textColor="#ff555966"
                android:textColorLink="#2655fe"
                android:id="@+id/tv_permission_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:lineSpacingExtra="5dp"/>
        </LinearLayout>
    </ScrollView>
    <FrameLayout
        android:id="@+id/flButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/llNormal"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/tv_agree"
                android:background="@drawable/shape_solid_ff2d55_radius_12dp"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="200dp"
                android:text="@string/txt_agree_use"/>
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ff1b1e29"
                android:gravity="center"
                android:id="@+id/tv_disagree"
                android:background="@drawable/shape_solid_fff7f8fc_radius_8dp"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:minWidth="200dp"
                android:text="@string/txt_un_agree"/>
            <View
                android:visibility="invisible"
                android:layout_width="200dp"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/ll_visitor"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/tv_LastAgree"
                android:background="@drawable/shape_solid_ff2d55_radius_12dp"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="200dp"
                android:text="@string/txt_agree_use"/>
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ff1b1e29"
                android:gravity="center"
                android:id="@+id/tv_disagreeAndQuit"
                android:background="@drawable/shape_solid_fff7f8fc_radius_8dp"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:minWidth="200dp"
                android:text="@string/txt_disagree_quit"/>
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ff1b1e29"
                android:gravity="center"
                android:id="@+id/tv_visitor"
                android:background="@drawable/shape_solid_fff7f8fc_radius_8dp"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:minWidth="200dp"
                android:text="@string/txt_visitor_more"/>
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
