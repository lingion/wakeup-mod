<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/empty_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/common_iv_listview_image"
            android:layout_width="160dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"/>
        <TextView
            android:textSize="@dimen/uxc_font_size_16"
            android:textStyle="bold"
            android:textColor="@color/c1_2"
            android:id="@+id/common_tv_listview_big_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:text="这里空空如也"/>
        <TextView
            android:textSize="@dimen/uxc_font_size_14"
            android:textColor="@color/c1_4"
            android:gravity="center"
            android:id="@+id/common_tv_listview_small_text"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="此处最多两行文本， 且需克制使用该模板哦~"
            android:lineSpacingMultiplier="1.3"/>
        <Button
            android:textSize="@dimen/uxc_font_size_16"
            android:id="@+id/user_bt_unlogin"
            android:layout_width="120dp"
            android:layout_height="@dimen/uxc_button_height_40"
            android:layout_marginTop="13dp"
            android:layout_marginBottom="13dp"
            android:text="立即发布"
            style="@style/BtnTypeFA"/>
    </LinearLayout>
</LinearLayout>
