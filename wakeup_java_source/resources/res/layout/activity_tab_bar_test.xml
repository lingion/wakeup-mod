<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:gravity="center"
            android:id="@+id/tab_test_show"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="点击"
            android:layout_weight="1"/>
        <TextView
            android:gravity="center"
            android:id="@+id/tab_test_next"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="点击2"
            android:layout_weight="1"/>
    </LinearLayout>
    <com.zuoyebang.design.tabbar.TabBarView
        android:id="@+id/tab_layout_homepage"
        android:background="#ffffff"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="@dimen/uxc_tab_bar_height"/>
    <com.zuoyebang.design.tabbar.TabBarView
        android:id="@+id/tab_layout_homepage11"
        android:background="#ffffff"
        android:visibility="gone"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="@dimen/uxc_tab_bar_height"
        android:layout_marginTop="20dp"/>
    <com.zuoyebang.design.tabbar.TabBarView
        android:id="@+id/tab_layout_homepage111"
        android:background="#ffffff"
        android:visibility="gone"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="@dimen/uxc_tab_bar_height"
        android:layout_marginTop="20dp"/>
    <com.zuoyebang.design.tabbar.TabBarView
        android:id="@+id/tab_layout_homepage2"
        android:background="#ffffff"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="@dimen/uxc_tab_bar_height"
        android:layout_marginTop="20dp"/>
    <com.zuoyebang.design.tabbar.TabBarView
        android:id="@+id/tab_layout_homepage3"
        android:background="#ffffff"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="@dimen/uxc_tab_bar_height"
        android:layout_marginTop="20dp"/>
    <com.zuoyebang.design.tabbar.TabBarView
        android:id="@+id/tab_layout_homepage4"
        android:background="#ffffff"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="@dimen/uxc_tab_bar_height"
        android:layout_marginTop="20dp"/>
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/scrollView_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </androidx.core.widget.NestedScrollView>
    <com.zuoyebang.design.test.tabbar.TestHomepageViewPager
        android:id="@+id/homepage_view_pager"
        android:background="#ffffff"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
