<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/common_ui_titlebar_default_heigh">
    <ImageButton
        android:id="@+id/btn_back"
        android:background="@null"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/nav_icon_return"
        android:scaleType="centerInside"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"/>
    <TextView
        android:textSize="@dimen/uxc_font_size_14"
        android:textColor="@color/common_ui_titlebar_text_black_template_selector"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_cancel"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:maxWidth="120dp"
        android:text="取消"
        android:maxLines="1"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"/>
</FrameLayout>
