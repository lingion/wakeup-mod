<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#333333"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/adscc_blur_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.suda.yzune.wakeupschedule.aaa.activity.search.manyquestions.SearchResultTouchImageView
            android:id="@+id/search_single_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"/>
    </FrameLayout>
    <View
        android:id="@+id/adscc_statusbar_bg"
        android:background="@drawable/shape_rectangle_gradient_00000000_99000000"
        android:layout_width="match_parent"
        android:layout_height="100dp"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/white_FFFFFF"
        android:layout_gravity="right"
        android:id="@+id/tvSearchType"
        android:background="@drawable/shape_gray_b8000000_14dp"
        android:paddingLeft="12dp"
        android:paddingTop="6dp"
        android:paddingRight="12dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:text="识别为拍屏，试试PC插件搜题 去试试"
        android:drawableRight="@drawable/icon_right_arrow"/>
    <com.suda.yzune.wakeupschedule.aaa.activity.questionsearch.camera.blur.BlurView
        android:id="@+id/adscc_blur_view"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <View
        android:id="@+id/search_single_img_cover"
        android:background="#29000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"/>
    <RelativeLayout
        android:id="@+id/adscc_titlebar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/adscc_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="16dp"
            android:src="@drawable/icon_pic_many_search_back_b"
            android:scaleType="fitCenter"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="12dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_gravity="right"
            android:id="@+id/admcc_recrop_guide_jump"
            android:background="@drawable/pic_many_title_guide_jump_bg"
            android:paddingLeft="12dp"
            android:paddingTop="6dp"
            android:paddingRight="10dp"
            android:paddingBottom="6dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="16dp"
            android:text="查看整页拍结果"
            android:includeFontPadding="false"
            android:drawableRight="@drawable/pic_many_title_guide_jump_arrow"
            android:drawablePadding="1dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
        <ImageView
            android:id="@+id/icon_result_guide"
            android:visibility="gone"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginRight="16dp"
            android:src="@drawable/icon_result_guide_white"
            android:scaleType="fitCenter"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <com.suda.yzune.wakeupschedule.aaa.activity.questionsearch.camera.widget.CustomCoordinatorLayout
        android:id="@+id/search_single_fus_ccl"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/adscc_container"
            android:background="@drawable/many_search_sliding_place_bg_b"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="16dp"
            app:behavior_hideable="true"
            app:behavior_peekHeight="48dp"
            app:layout_behavior="@string/view_pager_bottom_sheet_behavior_single">
            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/fl_search_app_bar_layout"
                android:background="@drawable/many_search_sliding_place_bg_b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:elevation="0dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <FrameLayout
                        android:id="@+id/search_sliding_place_iv"
                        android:layout_width="match_parent"
                        android:layout_height="20dp">
                        <View
                            android:layout_gravity="center"
                            android:background="@drawable/search_slide_bg"
                            android:layout_width="36dp"
                            android:layout_height="4dp"/>
                    </FrameLayout>
                    <androidx.recyclerview.widget.RecyclerView
                        android:orientation="horizontal"
                        android:id="@+id/recyclerview"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_10dp"
                        android:layout_marginRight="@dimen/margin_10dp"
                        android:nestedScrollingEnabled="false"/>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/search_result_tab"
                        android:background="@drawable/bg_search_result_tab"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>
                </LinearLayout>
            </com.google.android.material.appbar.AppBarLayout>
            <RelativeLayout
                android:gravity="center"
                android:id="@+id/rlAdContainer"
                android:background="@color/white"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <RelativeLayout
                android:id="@+id/adscc_error_container"
                android:background="#ffffff"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <FrameLayout
                android:layout_gravity="bottom|center_horizontal"
                android:background="@color/transparent"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <com.suda.yzune.wakeupschedule.aaa.activity.questionsearch.camera.widget.SearchResultPager
                    android:id="@+id/search_pager"
                    android:background="#ffffff"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <FrameLayout
                    android:id="@+id/frame_webview_layout"
                    android:background="@color/transparent"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </FrameLayout>
        </LinearLayout>
    </com.suda.yzune.wakeupschedule.aaa.activity.questionsearch.camera.widget.CustomCoordinatorLayout>
</FrameLayout>
