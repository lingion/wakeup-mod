<?xml version="1.0" encoding="utf-8"?>
<com.kwad.sdk.widget.KSFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.kwad.sdk.widget.KSFrameLayout
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="280dp">
        <com.kwad.sdk.widget.KSLinearLayout
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:id="@+id/ksad_draw_live_card_bg"
            android:background="@drawable/ksad_draw_live_actionbar_shop_bg"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginLeft="35dp"
            android:layout_marginRight="35dp">
            <TextView
                android:textSize="20sp"
                android:textColor="#000"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/ksad_draw_live_end_app_name"
                android:layout_width="match_parent"
                android:layout_height="27dp"
                android:layout_marginLeft="63dp"
                android:layout_marginTop="85dp"
                android:layout_marginRight="63dp"
                android:layout_marginBottom="8dp"
                android:text="直播中"
                android:maxLines="1"/>
            <TextView
                android:textSize="15sp"
                android:textColor="#666"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/ksad_draw_live_end_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginBottom="13dp"
                android:text="点击进入直播间"
                android:maxLines="2"/>
            <TextView
                android:textSize="15sp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:layout_gravity="bottom"
                android:id="@+id/ksad_live_actionbar_btn"
                android:background="@drawable/ksad_draw_live_button_bg"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginLeft="26.5dp"
                android:layout_marginRight="26.5dp"
                android:layout_marginBottom="27dp"
                android:text="进入直播间"/>
        </com.kwad.sdk.widget.KSLinearLayout>
        <com.kwad.components.ad.draw.presenter.livecard.KsLiveEndAuthorView
            android:layout_gravity="top|center_horizontal"
            android:id="@+id/ksad_draw_author_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </com.kwad.sdk.widget.KSFrameLayout>
</com.kwad.sdk.widget.KSFrameLayout>
