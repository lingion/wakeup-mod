<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingLeft="4dp"
    android:paddingTop="4dp"
    android:paddingRight="4dp"
    android:paddingBottom="6dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="4dp">
    <androidx.cardview.widget.CardView
        android:id="@+id/id_ad_image_layout"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:cardBackgroundColor="#99000000"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/id_ad_blur"
            android:background="@android:color/transparent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/id_ad_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"/>
        <com.fastad.api.player.VideoPlayLayout
            android:layout_gravity="center"
            android:id="@+id/id_ad_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/id_ad_interact_area"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/id_ad_interact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"/>
            <TextView
                android:textSize="7dp"
                android:textColor="#ffffff"
                android:layout_gravity="bottom|center_horizontal"
                android:id="@+id/id_ad_interact_text"
                android:background="@drawable/interact_background"
                android:paddingLeft="6dp"
                android:paddingTop="2dp"
                android:paddingRight="6dp"
                android:paddingBottom="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="12dp"
        android:textColor="#141414"
        android:ellipsize="end"
        android:id="@+id/id_ad_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:maxLines="2"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/id_ad_image_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/id_ad_image_layout"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/id_adn_icon"
        android:layout_width="40dp"
        android:layout_height="16dp"
        android:scaleType="fitStart"
        android:layout_alignBottom="@+id/id_ad_image_layout"
        android:layout_marginStart="6dp"
        android:layout_toEndOf="@+id/id_ad_image_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/id_ad_image_layout"/>
</androidx.constraintlayout.widget.ConstraintLayout>
