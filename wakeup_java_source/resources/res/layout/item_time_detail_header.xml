<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.textview.MaterialTextView
        android:textColor="?attr/colorPrimary"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="要用多少节就设置多少节呀，多余的节数不用管~\10如果想修改课表显示的节数，请去设置课表数据中的「一天课程节数」"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/ll_table_name"
        style="@style/settings_item_ll">
        <com.google.android.material.textview.MaterialTextView
            android:text="时间表名称"
            style="@style/settings_item_tv_main"/>
        <com.google.android.material.textview.MaterialTextView
            android:layout_gravity="center_vertical"
            android:id="@+id/tv_table_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="默认"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat style="@style/settings_item_ll">
        <com.google.android.material.textview.MaterialTextView
            android:text="每节课时长相同"
            style="@style/settings_item_tv_main"/>
        <androidx.appcompat.widget.SwitchCompat
            android:layout_gravity="center_vertical"
            android:id="@+id/s_time_same"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="vertical"
        android:id="@+id/ll_set_length"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_marginBottom="-16dp"
            style="@style/settings_item_ll">
            <com.google.android.material.textview.MaterialTextView
                android:text="每节课时长"
                style="@style/settings_item_tv_main"/>
            <com.google.android.material.textview.MaterialTextView
                android:layout_gravity="center_vertical"
                android:id="@+id/tv_time_length"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50"
                android:layout_marginStart="16dp"/>
            <com.google.android.material.textview.MaterialTextView
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 分钟"
                android:layout_marginEnd="16dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.slider.Slider
                android:layout_gravity="center_vertical"
                android:id="@+id/sb_time_length"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:stepSize="1"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:haloRadius="0dp"
                app:thumbColor="@android:color/white"
                app:thumbElevation="0dp"
                app:thumbRadius="4dp"
                app:tickColor="@android:color/transparent"
                app:trackHeight="16dp"/>
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/ib_edit"
                android:layout_width="40dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_outline_edit_24"
                android:layout_marginEnd="16dp"
                app:tint="@color/blue"
                style="@style/ButtonBackground"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
