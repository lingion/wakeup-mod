<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/iv_appwidget_pic_bg"
        android:background="@drawable/appwidget_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <ImageView
        android:id="@+id/iv_appwidget"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/appwidget_bg"/>
    <RelativeLayout
        android:id="@+id/rl_appwidget"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/rl_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp">
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="2dp"
                    android:text="8月9日"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:id="@+id/tv_schedule_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="我的课表"
                        android:maxLines="1"
                        android:maxLength="12"/>
                    <TextView
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:id="@+id/tv_week"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" | 第1周    周四"/>
                </LinearLayout>
            </LinearLayout>
            <ImageView
                android:id="@+id/iv_settings"
                android:padding="4dp"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_outline_tune_24"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@+id/iv_next"/>
            <ImageView
                android:id="@+id/iv_next"
                android:padding="4dp"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                android:rotation="180"
                android:layout_alignParentEnd="true"/>
            <ImageView
                android:id="@+id/iv_back"
                android:padding="4dp"
                android:visibility="gone"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <ListView
            android:id="@+id/lv_course"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="28dp"
            android:divider="@null"
            android:layout_below="@+id/rl_title"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@android:id/empty"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/rl_title"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:paddingHorizontal="16dp">
            <ImageView
                android:id="@+id/empty_image"
                android:layout_width="wrap_content"
                android:layout_height="120dp"
                android:src="@drawable/ic_schedule_empty"/>
            <TextView
                android:textSize="12dp"
                android:id="@+id/empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="请去系统设置允许 App 后台运行和自启哦"
                android:lineSpacingExtra="8dp"
                android:textAlignment="center"/>
        </LinearLayout>
    </RelativeLayout>
    <FrameLayout
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/fl_course_left_count"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="5dp">
        <TextView
            android:textSize="12sp"
            android:textColor="#ff87888a"
            android:layout_gravity="center"
            android:id="@+id/tv_course_left_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableRight="@drawable/ic_widget_course_left_count"
            android:drawablePadding="2dp"/>
    </FrameLayout>
</FrameLayout>
