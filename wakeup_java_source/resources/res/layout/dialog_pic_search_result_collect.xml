<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bg_open_float_permission_dialog"
    android:layout_width="296dp"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/iv_portrait"
        android:background="@drawable/bg_collect_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"/>
    <com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateImageView
        android:id="@+id/siv_close"
        android:background="@drawable/icon_pic_search_reuslt_feedback_close_new"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginTop="11dp"
        android:layout_marginRight="10.5dp"
        android:layout_alignParentRight="true"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/black_1B1E29"
        android:gravity="center_horizontal"
        android:id="@+id/tv_sub_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/txt_collect_hint"
        android:includeFontPadding="false"
        android:layout_below="@+id/iv_portrait"
        android:layout_centerHorizontal="true"
        android:lineSpacingExtra="4dp"
        android:lineSpacingMultiplier="1.3"/>
    <com.suda.yzune.wakeupschedule.aaa.widget.stateview.StateTextView
        android:textSize="16sp"
        android:textColor="#ffffffff"
        android:gravity="center"
        android:id="@+id/stv_open"
        android:background="@drawable/bg_open_float_permission_dialog_open_button"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginLeft="@dimen/margin_20dp"
        android:layout_marginTop="28dp"
        android:layout_marginRight="@dimen/margin_20dp"
        android:layout_marginBottom="@dimen/margin_20dp"
        android:text="@string/txt_go_to"
        android:layout_below="@+id/tv_sub_title"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
