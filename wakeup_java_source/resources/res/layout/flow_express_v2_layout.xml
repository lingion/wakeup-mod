<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="groupImage"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="16dp"
        android:textStyle="bold"
        android:textColor="#141414"
        android:ellipsize="end"
        android:id="@+id/id_ad_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:maxLines="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="32dp"/>
    <TextView
        android:textSize="12dp"
        android:textColor="#626466"
        android:ellipsize="end"
        android:id="@+id/id_ad_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="1"
        android:layout_below="@+id/id_ad_title"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/id_ad_images_layout"
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:layout_marginTop="16dp"
        android:layout_below="@+id/id_ad_desc"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="#ffffff"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/id_ad_image1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="#ffffff"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/id_ad_image2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:cardBackgroundColor="#ffffff"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/id_ad_image3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/id_adn_logo_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_below="@+id/id_ad_images_layout"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <ImageView
            android:id="@+id/id_adn_icon"
            android:layout_width="37dp"
            android:layout_height="16dp"
            android:scaleType="fitStart"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="12dp"
            android:textColor="#141414"
            android:gravity="center"
            android:id="@+id/id_ad_click_look"
            android:background="@drawable/click_look_ad_shape"
            android:layout_width="72dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <View
        android:id="@+id/id_line"
        android:background="#edeff0"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="12dp"
        android:layout_below="@+id/id_adn_logo_layout"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <com.homework.fastad.common.tool.AppInfoLayout
        android:id="@+id/id_app_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="14dp"
        android:layout_below="@+id/id_line"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:layout_marginEnd="9dp"
        android:layout_alignParentEnd="true">
        <ImageView
            android:layout_gravity="end|top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/gray_close_ad"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/id_ad_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>
</RelativeLayout>
