<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/uxc_card_hot_comment_bg_v2"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/small_imgfly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true">
        <com.zuoyebang.design.widget.RoundRecyclingImageView
            android:id="@+id/small_img"
            android:layout_width="69dp"
            android:layout_height="69dp"
            android:src="@drawable/common_uxc_placeholder_loading"
            android:scaleType="centerCrop"
            app:corner_radius="@dimen/F_Small"
            app:r_border_color="@color/c1_8"
            app:r_border_width="@dimen/uxc_avatar_icon_boarder_size_f"
            app:resize_bitmap="false"/>
        <FrameLayout
            android:id="@+id/uxc_card_shade"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="69dp">
            <ImageView
                android:layout_gravity="bottom"
                android:background="@drawable/uxc_card_video_shade_bottom_v2"
                android:layout_width="69dp"
                android:layout_height="20dp"/>
            <ImageView
                android:layout_gravity="top"
                android:background="@drawable/uxc_card_video_shade_top_v2"
                android:layout_width="69dp"
                android:layout_height="49dp"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/video_icon_iv"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/uxc_card_video_icon_v2"/>
        </FrameLayout>
    </FrameLayout>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/c1_2"
        android:ellipsize="end"
        android:id="@+id/content_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:text="每天一句英语鼓励自己你生而 而为赢，但你"
        android:maxLines="2"
        android:includeFontPadding="false"
        android:layout_toRightOf="@+id/small_imgfly"
        android:layout_centerVertical="true"
        android:lineSpacingExtra="4dp"/>
</RelativeLayout>
